<mah:MetroWindow x:Class="UkiChat.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:extensions="clr-namespace:UkiChat.Extensions"
        xmlns:mvvm="http://prismlibrary.com/"
        mc:Ignorable="d"
        mvvm:ViewModelLocator.AutoWireViewModel="True"
        Title="{extensions:Loc Key=settings.title}"
        Icon="Assets/icon.ico"
        Height="600" Width="900"
        MinHeight="400" MinWidth="500"
        Background="#FF1E1E1E"
        WindowTitleBrush="{DynamicResource MahApps.Brushes.Accent3}"
        NonActiveWindowTitleBrush="#2d2c34"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        NonActiveGlowBrush="#2d2c34"
        BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1"
        TitleBarHeight="32"
        TitleForeground="White"
        SaveWindowPosition="True"
        WindowTransitionsEnabled="False"
        ShowMaxRestoreButton="False"
        ShowIconOnTitleBar="True"
        TitleCharacterCasing="Normal"
        >
    <mah:MetroWindow.IconTemplate>
        <DataTemplate>
            <Image Source="{Binding}" Width="24" Height="24" />
        </DataTemplate>
    </mah:MetroWindow.IconTemplate>

    <Grid>
        <wpf:WebView2 HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Source="{Binding WebSource}" />
    </Grid>
</mah:MetroWindow>
