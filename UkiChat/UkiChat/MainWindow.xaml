<mah:MetroWindow x:Class="UkiChat.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 xmlns:mvvm="http://prismlibrary.com/"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:extensions="clr-namespace:UkiChat.Extensions"
                 mc:Ignorable="d"
                 mvvm:ViewModelLocator.AutoWireViewModel="True"
                 Title="UkiChat"
                 Height="600" Width="900"
                 MinHeight="400" MinWidth="500"
                 Background="#FF1E1E1E"
                 WindowTitleBrush="{DynamicResource MahApps.Brushes.WindowTitle}"
                 NonActiveWindowTitleBrush="{DynamicResource MahApps.Brushes.WindowTitle.NonActive}"
                 GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
                 BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                 BorderThickness="1"
                 TitleBarHeight="32"
                 TitleForeground="White"
                 SaveWindowPosition="True"
                 WindowTransitionsEnabled="False"
                 ShowIconOnTitleBar="True"
                 TitleCharacterCasing="Normal"
                 >

    <Grid>
        <wpf:WebView2 HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Source="{Binding WebSource}" />
    </Grid>

</mah:MetroWindow>
