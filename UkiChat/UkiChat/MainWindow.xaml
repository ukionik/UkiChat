<mah:MetroWindow x:Class="UkiChat.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 xmlns:mvvm="http://prismlibrary.com/"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:extensions="clr-namespace:UkiChat.Extensions"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 mc:Ignorable="d"
                 mvvm:ViewModelLocator.AutoWireViewModel="True"
                 Title="UkiChat v0.3.2"
                 Icon="Assets/icon.ico"
                 Height="600" Width="900"
                 MinHeight="400" MinWidth="350"
                 Background="#FF1E1E1E"
                 WindowTitleBrush="{DynamicResource MahApps.Brushes.Accent3}"
                 NonActiveWindowTitleBrush="#2d2c34"
                 GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
                 NonActiveGlowBrush="#2d2c34"
                 BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                 BorderThickness="1"
                 TitleBarHeight="32"
                 TitleForeground="White"
                 SaveWindowPosition="True"
                 WindowTransitionsEnabled="False"
                 ShowIconOnTitleBar="True"
                 TitleCharacterCasing="Normal"
                 >
    <mah:MetroWindow.IconTemplate>
        <DataTemplate>
            <Image Source="{Binding}" Width="24" Height="24" />
        </DataTemplate>
    </mah:MetroWindow.IconTemplate>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding OpenSettingsWindowCommand}" ToolTip="Settings">
                <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" />
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <wpf:WebView2 Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Source="{Binding WebSource}" />

        <StatusBar Grid.Row="1" Background="#2d2c34" Foreground="#CCCCCC" Height="24">
            <StatusBarItem Padding="6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="Twitch" Width="16" Height="16"
                                               Margin="0,0,5,0" VerticalAlignment="Center"
                                               Foreground="#9146FF" />
                    <TextBlock Text="{Binding TwitchViewerCount}" FontSize="14" VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem Padding="6,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{StaticResource VkVideoLiveIcon}" Width="16" Height="16"
                           Margin="0,0,5,0" VerticalAlignment="Center" Stretch="Uniform" />
                    <TextBlock Text="{Binding VkVideoLiveViewerCount}" FontSize="14" VerticalAlignment="Center" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>

</mah:MetroWindow>
